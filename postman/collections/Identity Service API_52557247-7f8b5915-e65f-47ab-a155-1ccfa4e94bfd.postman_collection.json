        {
          "name": "{id}",
          "item": [
            {
              "name": "Get user by ID",
              "event": [
                {
                  "id": "b9ef6a12-704e-4d83-892c-73d2b742587c",
                  "listen": "test",
                  "script": {
                    "id": "6004da2e-5f8b-454a-abc0-278aba672948",
                    "exec": [
                      "// ===== CONTRACT TESTS =====",
                      "",
                      "// [Positive] Status code is 200 for a valid user",
                      "pm.test('[Contract] Status code is 200', () => {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "// [Positive] Response Content-Type is application/json",
                      "pm.test('[Contract] Response Content-Type is application/json', () => {",
                      "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/html; charset=utf-8');",
                      "});",
                      "",
                      "// [Positive] Response body is an object (not an array)",
                      "pm.test('[Contract] Response body is an object', () => {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json).to.be.an('object').and.not.an('array');",
                      "});",
                      "",
                      "// [Positive] Response has required fields: id, name, email",
                      "pm.test('[Contract] Response contains id, name, and email fields', () => {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json).to.have.property('id');",
                      "    pm.expect(json).to.have.property('name');",
                      "    pm.expect(json).to.have.property('email');",
                      "});",
                      "",
                      "// [Positive] Returned id matches the requested path variable",
                      "pm.test('[Contract] Returned id matches the requested :id', () => {",
                      "    const json = pm.response.json();",
                      "    const requestedId = pm.request.url.variables.get('id');",
                      "    if (requestedId) {",
                      "        pm.expect(String(json.id)).to.equal(String(requestedId));",
                      "    }",
                      "});",
                      "",
                      "// [Positive] name and email are non-empty strings",
                      "pm.test('[Contract] name and email are non-empty strings', () => {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json.name).to.be.a('string').and.not.empty;",
                      "    pm.expect(json.email).to.be.a('string').and.not.empty;",
                      "});",
                      "",
                      "// [Negative] 404 is returned for a non-existent user ID",
                      "pm.test('[Contract - Negative] Non-existent ID returns 404', () => {",
                      "    // This test is only evaluated when the response is 404",
                      "    if (pm.response.code === 404) {",
                      "        const json = pm.response.json();",
                      "        pm.expect(json).to.have.property('error').or.have.property('message');",
                      "    } else {",
                      "        pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                      "    }",
                      "});",
                      "",
                      "// ===== PERFORMANCE TESTS =====",
                      "",
                      "// [Positive] Response time is under 800ms",
                      "pm.test('[Performance] Response time is under 1000ms', () => {",
                      "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                      "});",
                      "",
                      "// [Negative] Response time does not exceed 2000ms",
                      "pm.test('[Performance] Response time does not exceed 2000ms', () => {",
                      "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
