                  "});",
                  "",
                  "// [Positive] Response Content-Type is application/json",
                  "pm.test('[Contract] Response Content-Type is application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "// [Positive] Response body is an object (not an array)",
                  "pm.test('[Contract] Response body is an object', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('object').and.not.an('array');",
                  "});",
                  "",
                  "",
                  "",
                  "// [Negative] Response does not contain a password or sensitive field",
                  "pm.test('[Contract - Negative] Response does not expose sensitive fields (password, secret)', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.not.have.property('password');",
                  "    pm.expect(json).to.not.have.property('secret');",
                  "});",
                  "",
                  "// [Negative] 400 is returned when required fields are missing (evaluated only on 400)",
                  "pm.test('[Contract - Negative] 400 response contains an error message', () => {",
