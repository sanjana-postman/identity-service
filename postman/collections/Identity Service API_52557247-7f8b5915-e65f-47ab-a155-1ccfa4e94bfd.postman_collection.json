                "exec": [
                  "// ===== CONTRACT TESTS =====",
                  "",
                  "// [Positive] Status code is 200",
                  "pm.test('[Contract] Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// [Positive] Response Content-Type is application/json",
                  "pm.test('[Contract] Response Content-Type is application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/html; charset=utf-8');",
                  "});",
                  "",
                  "// [Positive] Response body is an array",
                  "pm.test('[Contract] Response body is an array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "// [Positive] Each user object has required fields: id, name, email",
                  "pm.test('[Contract] Each user has id, name, and email fields', () => {",
                  "    const json = pm.response.json();",
                  "    json.forEach(user => {",
                  "        pm.expect(user).to.have.property('id');",
                  "        pm.expect(user).to.have.property('name');",
                  "        pm.expect(user).to.have.property('email');",
                  "    });",
                  "});",
                  "",
                  "// [Positive] id is a string or number, name and email are strings",
                  "pm.test('[Contract] User field types are correct', () => {",
                  "    const json = pm.response.json();",
                  "    json.forEach(user => {",
                  "        pm.expect(user.id).to.satisfy(id => typeof id === 'string' || typeof id === 'number');",
                  "        pm.expect(user.name).to.be.a('string');",
                  "        pm.expect(user.email).to.be.a('string');",
                  "    });",
                  "});",
                  "",
                  "// [Negative] Response is not an object (should be an array, not a wrapped object)",
                  "pm.test('[Contract] Response is not a plain object (must be an array)', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.not.be.an('object').that.has.property('users');",
                  "});",
                  "",
                  "// ===== PERFORMANCE TESTS =====",
                  "",
                  "// [Positive] Response time is under 800ms",
